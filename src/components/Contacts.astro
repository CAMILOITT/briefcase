---
import { CONTACT_LINKS } from '../const/socialLinks'
import FormContact from './FormContact.astro'
import Notification from './Notification.astro'
---

<section
  class="contacts"
  id="Contact">
  <div class="contact-container">
    <div class="contact-card">
      <h2 class="contact-title">Enviame un mensaje</h2>
      <FormContact />
    </div>

    <div class="social-footer">
      <h3>Tambien puedes contactarme mediante</h3>
      <div class="social-links">
        {
          CONTACT_LINKS.map(({ name, url, Icon }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
              arial-label={`link to me ${name} profile`}>
              <Icon />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .contacts {
    background: #000;
    padding: 6rem 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .contact-container {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    align-items: center;
  }

  .contact-card {
    background: #1a1a2e;
    padding: 3rem;
    border-radius: 20px;
    width: 100%;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .contact-title {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 1.5rem;
    color: #fff;
  }

  .social-footer {
    text-align: center;
    background: #1a1a2e;
    padding: 2rem;
    border-radius: 20px;
    width: 100%;
  }

  .social-footer h3 {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: #ccc;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .social-link {
    background: #eee;
    color: #000;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    transition: 0.3s;
  }

  .social-link:hover {
    transform: translateY(-5px);
    background: #fff;
  }
</style>
