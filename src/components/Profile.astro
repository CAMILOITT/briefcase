---
import IntroInfo from './IntroInfo.astro'
import Skills from './Skills.astro'
---

<section
  class="intro"
  id="Intro">
  <div class="intro-left">
    <IntroInfo />
    <Skills />
  </div>
  <div class="intro-right">
    <!-- Desktop Chat -->
    <div class="chat-widget desktop-chat">
      <div class="chat-header">
        <div class="ai-status">
          <div class="status-dot"></div>
          <span>Camilo AI Assistant</span>
        </div>
      </div>
      <div
        class="chat-content"
        id="chat-messages-desktop">
        <div class="message-box ai">
          <div class="message-header">
            <span class="avatar">🤖</span>
            <span class="sender-name">Camilo AI</span>
          </div>
          <div class="message-text">
            ¡Hola! Soy el asistente virtual de Camilo. ¿Qué te gustaría saber
            sobre su carrera?
          </div>
          <span class="timestamp">ahora</span>
        </div>
      </div>
      <div class="chat-footer">
        <div class="input-wrapper">
          <input
            type="text"
            placeholder="Escribe tu mensaje..."
            class="chat-input"
            id="chat-input-desktop"
          />
          <button
            class="chat-send"
            id="chat-send-desktop">
            <span class="btn-text">Enviar</span>
            <span class="cooldown-timer hidden">10s</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Floating Button -->
  <button
    id="ai-chat-toggle"
    class="mobile-chat-btn"
    aria-label="Abrir chat con IA">
    <svg
      viewBox="0 0 24 24"
      width="30"
      height="30"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
      ></path>
      <path d="M12 7v4M12 15h.01"></path>
    </svg>
  </button>

