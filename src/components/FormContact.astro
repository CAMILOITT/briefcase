---
import WarningIcon from '../assets/icons/info/WarningIcon.astro'
---

<script>
  import { openNotification } from './notification/actions'
  
  const form = document.querySelector('#FormContact') as HTMLFormElement
  const inputs = form?.querySelectorAll('.form-input, .form-textarea')
  const submitBtn = form?.querySelector('.form-btn') as HTMLButtonElement

  const validateEmail = (email: string) => {
    return String(email)
      .toLowerCase()
      .match(
        /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
      )
  }

  const showError = (input: HTMLElement, message: string) => {
    const group = input.closest('.input-group')
    const errorEl = group?.querySelector('.error-msg') as HTMLElement
    if (errorEl) {
      errorEl.textContent = message
      errorEl.classList.remove('hidden')
    }
    input.classList.add('input-error')
  }

  const hideError = (input: HTMLElement) => {
    const group = input.closest('.input-group')
    const errorEl = group?.querySelector('.error-msg') as HTMLElement
    if (errorEl) {
      errorEl.classList.add('hidden')
    }
    input.classList.remove('input-error')
  }

  const validateInput = (input: HTMLInputElement | HTMLTextAreaElement) => {
    const name = input.getAttribute('name')
    const value = input.value.trim()

    if (!value) {
      showError(input, 'Este campo es obligatorio')
      return false
    }

    if (name === 'name' && value.length < 3) {
      showError(input, 'El nombre debe tener al menos 3 caracteres')
      return false
    }

    if (name === 'email' && !validateEmail(value)) {
      showError(input, 'Por favor, ingresa un correo electrónico válido')
      return false
    }

    if (name === 'message' && value.length < 10) {
      showError(input, 'El mensaje debe ser más descriptivo (mín. 10 caracteres)')
      return false
    }

    hideError(input)
    return true
  }

  inputs?.forEach(input => {
    input.addEventListener('input', () => {
      validateInput(input as HTMLInputElement)
    })

    input.addEventListener('blur', () => {
      validateInput(input as HTMLInputElement)
    })
  })

  form?.addEventListener('submit', async e => {
    e.preventDefault()

    const formElements = form.elements as any
    const name = formElements.name
    const email = formElements.email
    const message = formElements.message

    const isNameValid = validateInput(name)
    const isEmailValid = validateInput(email)
    const isMessageValid = validateInput(message)

    if (!isNameValid || !isEmailValid || !isMessageValid) {
      openNotification({
        time: 4000,
        message: 'Por favor, corrige los errores en el formulario.',
        className: { add: ['error'], remove: ['success', 'hidden'] },
      })
      return
    }

    submitBtn.disabled = true
    submitBtn.textContent = 'Enviando...'

    const data = JSON.stringify({
      name: name.value,
      email: email.value,
      message: message.value,
    })

    try {
      const res = await fetch('/api/email/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: data,
      })
      
      if (!res.ok) throw new Error('Error al enviar el mensaje')
      
      const resMessage = await res.text()

      openNotification({
        time: 5000,
        message: '¡Mensaje enviado con éxito!',
        className: { add: ['success'], remove: ['error', 'hidden'] },
      })

      form.reset()
      inputs.forEach(input => hideError(input as HTMLElement))
    } catch (error) {
      openNotification({
        time: 5000,
        message: 'Hubo un error al enviar el email. Inténtalo de nuevo.',
        className: { add: ['error'], remove: ['success', 'hidden'] },
      })
    } finally {
      submitBtn.disabled = false
      submitBtn.textContent = 'Enviar'
    }
  })
</script>

<form
  class="form-contact"
  id="FormContact"
  novalidate>
  <div class="input-group">
    <input
      type="text"
      name="name"
      placeholder="Escriba su nombre..."
      class="form-input"
      autocomplete="name"
    />
    <p class="error-msg hidden"></p>
  </div>

  <div class="input-group">
    <input
      type="email"
      name="email"
      placeholder="Escriba su email..."
      class="form-input"
      autocomplete="email"
    />
    <p class="error-msg hidden"></p>
  </div>

  <div class="input-group">
    <textarea
      name="message"
      placeholder="Ingrese un mensaje..."
      class="form-textarea"></textarea>
    <p class="error-msg hidden"></p>
  </div>

  <button
    type="submit"
    class="form-btn">
    Enviar
  </button>
</form>

<style>
  .form-contact {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .form-input,
  .form-textarea {
    background: #d9d9d9;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    font-size: 1rem;
    color: #333;
    width: 100%;
    border: 2px solid transparent;
    outline: none;
    transition: all 0.3s ease;
  }

  .form-input:focus,
  .form-textarea:focus {
    background: #fff;
    border-color: #2d2d4a;
    box-shadow: 0 0 10px rgba(45, 45, 74, 0.1);
  }

  .input-error {
    border-color: #ff4d4d !important;
    background: #fff0f0 !important;
  }

  .form-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .error-msg {
    color: #ff4d4d;
    font-size: 0.85rem;
    margin-left: 0.5rem;
    transition: opacity 0.3s ease;
  }

  .hidden {
    display: none;
    opacity: 0;
  }

  .form-btn {
    background: #2d2d4a;
    color: #fff;
    padding: 1rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 0.5rem;
    border: none;
  }

  .form-btn:hover:not(:disabled) {
    background: #3d3d5a;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  .form-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
